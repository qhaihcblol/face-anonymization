# .dockerignore - Exclude files from Docker build context

# Git
.git
.gitignore
.gitattributes

# Environment & Secrets
.env
.env.*
!.env.example
*.pem
*.key

# IDE & Editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/
*.cover
*.lcov

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Next.js
.next/
out/

# Testing
coverage/
.test-results/

# Documentation
docs/
*.md
!README.MD

# Test files
test_videos/
test_scripts/
outputs/
temp/
logs/

# Docker (don't include docker-compose in build context)
docker-compose*.yml
docker-compose*.yaml
!docker/

# Scripts not needed in production
scripts/download_onnx_files.py

# Hidden files (except docker directory)
.*
!.dockerignore
