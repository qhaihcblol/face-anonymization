# Reverse proxy cho FaceGuard full-stack (frontend :3000 + backend :8000 trên cùng VM).
# Đặt file vào /etc/nginx/sites-available/, symlink sang sites-enabled, sửa server_name,
# rồi chạy `certbot --nginx -d app.your-domain.com -d api.your-domain.com` để cấp TLS.
#
# Lưu ý cho app này:
#   - CẢ HAI domain cần client_max_body_size lớn: upload đi browser -> frontend -> backend.
#   - api.your-domain.com phải forward WebSocket (/api/live/ws) cho live camera.
#   - Timeout dài cho job xử lý video / phiên live.

# ---------- Frontend (Next.js) ----------
server {
    listen 80;
    server_name app.your-domain.com;

    client_max_body_size 2048M;   # upload chảy qua Next server tới backend

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_request_buffering off;
    }
}

# ---------- Backend (FastAPI) ----------
server {
    listen 80;
    server_name api.your-domain.com;

    client_max_body_size 2048M;   # khớp VIDEO_MAX_UPLOAD_MB

    # WebSocket cho live camera (browser nối thẳng vào đây).
    location /api/live/ws {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # REST API.
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_request_buffering off;
    }
}
